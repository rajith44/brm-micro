# Copy to .env.production and set your real values before building/deploying.
# IMPORTANT: also set NEXT_PUBLIC_API_URL in your hosting panel / server env when running npm start.

# Public URL of the Laravel admin/API (must be reachable from the internet).
# Example: https://admin.micro-art.co.uk  (NOT 127.0.0.1)
NEXT_PUBLIC_API_URL=https://admin.micro-art.co.uk
